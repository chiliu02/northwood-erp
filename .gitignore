# Node / SPAs (each SPA has its own .gitignore too; this is a safety net
# at the workspace root in case a new SPA is added)
**/node_modules/
**/dist/
**/dist-ssr/
.vite/

# Environment / secrets — never commit local override files
.env
.env.*
*.local

# Claude Code — commit project-shared bits (commands/, skills/, agents/,
# settings.json) but ignore per-developer session state below.
.claude/projects/
.claude/todos/
.claude/shell-snapshots/
.claude/statsig/
.claude/*.log
.claude/settings.local.json

# Historical doc snapshots — repo-private working notes
t3/

