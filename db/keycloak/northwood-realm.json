  "clients": [
    {
      "clientId": "northwood-bff",
      "name": "Northwood ERP BFF",
      "description": "Confidential client used by erp-web-ui-bff for the OIDC authorization-code flow. Holds the access token in a server-side session and forwards it as Bearer on every call to a Northwood service.",
      "enabled": true,
      "publicClient": false,
      "secret": "northwood-bff-secret",
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:8089/login/oauth2/code/keycloak",
        "http://localhost:8089/*",
        "http://localhost:5174/*"
      ],
      "webOrigins": [
        "http://localhost:8089",
        "http://localhost:5173",
        "http://localhost:5174"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8089/##http://localhost:5173/##http://localhost:5174/"
      },
      "fullScopeAllowed": true
    },
    {
      "clientId": "northwood-spa",
      "name": "Northwood ERP SPA (reserved)",
      "description": "PKCE public client reserved for direct SPA<->Keycloak OIDC if the BFF-as-proxy mode is ever swapped out. Not used in Slice A — the BFF holds the token.",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:8089/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:8089"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "defaultRoles": ["offline_access", "uma_authorization"]
}
