  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": true,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": false,
  "verifyEmail": false,
  "sslRequired": "none",
  "accessTokenLifespan": 1800,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "roles": {
    "realm": [
      { "name": "catalog_manager",      "description": "Emma — product CRUD, pricing, reorder policy, make-vs-buy, discontinue" },
      { "name": "sales_clerk",          "description": "Sarah — place orders, view 360, view ATP" },
      { "name": "sales_manager",        "description": "Sales manager tier — cancel orders, override pricing" },
      { "name": "warehouse_clerk",      "description": "Mike — stock movements, goods receipts, shipments, reservation visibility" },
      { "name": "warehouse_manager",    "description": "Warehouse manager tier — force-release reservations, post stock adjustments" },
      { "name": "production_planner",   "description": "Linda — view board, view shortages, set priority, edit/activate BOM" },
      { "name": "production_supervisor","description": "Production supervisor tier — cancel WO, skip operation, force-complete" },
      { "name": "purchasing_clerk",     "description": "Tom — create PR/PO (draft), post goods receipts, view PO tracking" },
      { "name": "purchasing_manager",   "description": "Purchasing manager tier — approve PO, author supplier prices, override 3-way match" },
      { "name": "accountant",           "description": "Olivia — record supplier invoices, record payments, view AR/AP" },
      { "name": "finance_manager",      "description": "Daniel — reverse journals, manual-approve/reject 3-way-match-failed invoices, view dashboard" },
      { "name": "auditor",              "description": "Read-only across every endpoint" },
      { "name": "sysadmin",             "description": "Keycloak realm admin only; no business-data permissions" }
