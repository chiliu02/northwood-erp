{
  "annotations": { "list": [] },
  "description": "Northwood ERP showcase observability board (§1D.5). Three rows: service health, bus health, a placed-order's journey.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "type": "row",
      "title": "Service health",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Services up",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 6 },
      "id": 101,
      "datasource": { "type": "prometheus", "uid": "northwood-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (up{job=\"northwood-services\"})",
          "legendFormat": "{{service}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" } }, "type": "value" },
            { "options": { "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          }
        }
      },
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "value_and_name",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "type": "timeseries",
      "title": "JVM heap used",
      "gridPos": { "x": 6, "y": 1, "w": 9, "h": 6 },
      "id": 102,
      "datasource": { "type": "prometheus", "uid": "northwood-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (jvm_memory_used_bytes{area=\"heap\", job=\"northwood-services\"})",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "HTTP requests/sec",
      "gridPos": { "x": 15, "y": 1, "w": 9, "h": 6 },
      "id": 103,
      "datasource": { "type": "prometheus", "uid": "northwood-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (rate(http_server_requests_seconds_count{job=\"northwood-services\"}[1m]))",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "type": "row",
      "title": "Bus health",
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 1 },
      "id": 200,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Outbox pending (per service)",
      "description": "northwood_outbox_pending — custom gauge polled on every Prometheus scrape (§1D.5). Inbox-only services (reporting) have no outbox_message table and emit no series. -1 means the gauge query failed unexpectedly on a service that does have the table.",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 7 },
      "id": 201,
      "datasource": { "type": "prometheus", "uid": "northwood-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "northwood_outbox_pending_rows",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "mappings": [
            { "options": { "-1": { "text": "n/a" } }, "type": "value" }
          ]
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Kafka publish rate (per topic)",
      "description": "rate(spring_kafka_template_seconds_count) — auto-instrumented by Spring Kafka's observation-enabled producer (§1D.2).",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 7 },
      "id": 202,
      "datasource": { "type": "prometheus", "uid": "northwood-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (name) (rate(spring_kafka_template_seconds_count[1m]))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "type": "barchart",
      "title": "Saga state distribution",
      "description": "northwood_saga_count — per (saga type, state). Refreshed every 15s (§1D.5).",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 7 },
      "id": 203,
      "datasource": { "type": "prometheus", "uid": "northwood-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "northwood_saga_count_rows",
          "legendFormat": "{{type}} · {{state}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 1, "fillOpacity": 80 }
        }
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "type": "row",
      "title": "A placed order's journey",
      "gridPos": { "x": 0, "y": 15, "w": 24, "h": 1 },
      "id": 300,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "table",
      "title": "Recent sales-order traces",
      "description": "Recent placed-order traces — TraceQL for the `http post /api/sales-orders` span (Spring Boot 4 / OTel names HTTP spans `http <lowercase-method> <route>`, not `POST …`). Drill-down: click a Trace ID to open these traces in Explore, or use the panel menu (⋮ top-right) → Explore, then click any Trace ID there — Tempo trace links only resolve inside Explore, not from a dashboard table cell. The Logs panel below correlates by trace id via the Loki↔Tempo wiring (§1D.0).",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 9 },
      "id": 301,
      "datasource": { "type": "tempo", "uid": "northwood-tempo" },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceqlSearch",
          "limit": 20,
          "tableType": "traces",
          "filters": [
            {
              "id": "span-name",
              "tag": "name",
              "operator": "=~",
              "scope": "intrinsic",
              "value": "(?i).*post /api/sales-orders.*",
              "valueType": "string"
            }
          ]
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Trace ID" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Tip: trace links don't open from here — use the panel menu (⋮ top-right) → Explore, then click a Trace ID there",
                    "targetBlank": true,
                    "url": "/explore?schemaVersion=1&panes=%7B%22tr%22%3A%7B%22datasource%22%3A%22northwood-tempo%22%2C%22queries%22%3A%5B%7B%22filters%22%3A%5B%7B%22id%22%3A%22span-name%22%2C%22operator%22%3A%22%3D%7E%22%2C%22scope%22%3A%22intrinsic%22%2C%22tag%22%3A%22name%22%2C%22value%22%3A%22%28%3Fi%29.*post+%2Fapi%2Fsales-orders.*%22%2C%22valueType%22%3A%22string%22%7D%5D%2C%22limit%22%3A20%2C%22queryType%22%3A%22traceqlSearch%22%2C%22refId%22%3A%22A%22%2C%22tableType%22%3A%22traces%22%2C%22datasource%22%3A%7B%22type%22%3A%22tempo%22%2C%22uid%22%3A%22northwood-tempo%22%7D%2C%22query%22%3A%22%22%7D%5D%2C%22range%22%3A%7B%22from%22%3A%22now-30m%22%2C%22to%22%3A%22now%22%7D%7D%7D&orgId=1"
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {}
    },
    {
      "type": "logs",
      "title": "Service logs (last 5 minutes)",
      "description": "All Spring-service logs from Loki. Trace IDs in each line are click-able and deep-link to Tempo via the `derivedFields` regex on the Loki datasource (§1D.0).",
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 10 },
      "id": 302,
      "datasource": { "type": "loki", "uid": "northwood-loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=~\".+-service|.+-bff\"}",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["northwood", "showcase"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Northwood — Overview",
  "uid": "northwood-overview",
  "version": 2,
  "weekStart": ""
}
