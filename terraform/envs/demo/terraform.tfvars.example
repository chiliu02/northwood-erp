# Copy to terraform.tfvars and adjust. All values shown are the defaults —
# uncomment only what you want to change.

# region      = "ap-southeast-2"
# name_prefix = "northwood-demo"

# Image tag the build script pushed to ECR for the 8 app images (a git SHA for real runs).
# image_tag = "latest"

# Empty schema instead of the populated demo dataset.
# load_seed_data = false

# Public HTTPS hostnames. dns_zone_name is an existing Route 53 public zone; the
# three surfaces are sub-domains of it. ui/auth get real Let's Encrypt certs from
# the on-box Caddy; the front door gets a CloudFront/ACM cert. All default under
# chiliu02.com — override for your own zone.
# dns_zone_name     = "chiliu02.com"
# front_door_domain = "www.northwood.chiliu02.com"   # welcome page (CloudFront + S3)
# ui_hostname       = "app.northwood.chiliu02.com"   # operational ERP UI (Caddy)
# auth_hostname     = "auth.northwood.chiliu02.com"  # Keycloak / OIDC issuer (Caddy)
# grafana_hostname  = "grafana.northwood.chiliu02.com"  # public READ-ONLY Grafana (Caddy → data :3000); "" => SSM-only
# acme_email        = ""                              # Let's Encrypt contact (optional)

# Observability: run the Tempo/Loki/Prometheus/Grafana box on the data EC2
# and point the apps at it. Set false to skip it (and its cost).
# enable_observability = true

# Keycloak northwood-bff client secret — must match config/keycloak/northwood-realm.json.
# bff_client_secret = "northwood-bff-secret"
